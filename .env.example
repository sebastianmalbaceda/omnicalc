# ========================================
# OmniCalc — Environment Variables
# ========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.

# ----- Application -----
NODE_ENV=development

# ----- Database (Neon PostgreSQL) -----
DATABASE_URL=postgresql://user:password@host.neon.tech/omnicalc?sslmode=require

# ----- Authentication (Better Auth) -----
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3001

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----- Payments — Stripe -----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# ----- Payments — RevenueCat (Mobile) -----
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# ----- Email (Resend) -----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@omnicalc.app

# ----- Monitoring (Sentry) -----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ----- Frontend URLs -----
MARKETING_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3002
APP_URL=http://localhost:3002

# ----- Mobile (Expo) -----
EXPO_PUBLIC_API_URL=http://localhost:3001

# ----- Desktop (Electron) -----
OMNICALC_URL=http://localhost:3002

# ----- Marketing (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3002

# ----- Web (Vite) -----
VITE_API_URL=http://localhost:3001
VITE_MARKETING_URL=http://localhost:3000
