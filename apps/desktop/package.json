{
  "name": "@omnicalc/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "OmniCalc Desktop App (Electron)",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "node scripts/build-renderer.js",
    "start": "electron .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist out"
  },
  "dependencies": {
    "@omnicalc/core-math": "workspace:*"
  },
  "devDependencies": {
    "@omnicalc/tsconfig": "workspace:*",
    "electron": "^34.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0"
  }
}
