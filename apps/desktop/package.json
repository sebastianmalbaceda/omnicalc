{
  "name": "@omnicalc/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "OmniCalc Desktop App (Electron)",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/dev-electron.js",
    "build": "npm run build:vite && npm run build:main",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json && npx tsc preload.ts --outDir dist/main/main --module CommonJS --target ES2022 --esModuleInterop --skipLibCheck",
    "start": "electron .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist out"
  },
  "dependencies": {
    "@omnicalc/core-math": "workspace:*",
    "electron-log": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@omnicalc/tsconfig": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^34.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
