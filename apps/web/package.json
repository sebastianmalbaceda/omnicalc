{
  "name": "@omnicalc/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/server/serve.ts",
    "dev:mobile": "cd ../mobile && npx expo start --web",
    "build": "cd ../mobile && npx expo export --platform web && tsc -p tsconfig.server.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node --env-file=../../.env dist/server/serve.js",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@omnicalc/core-math": "workspace:*",
    "@omnicalc/db": "workspace:*",
    "@prisma/client": "^6.19.2",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "hono": "^4.6.0",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@omnicalc/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
