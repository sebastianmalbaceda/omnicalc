{
  "extends": "@omnicalc/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist/server",
    "rootDir": "./src/server",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": true
  },
  "include": ["src/server"],
  "exclude": ["node_modules", "dist"]
}
