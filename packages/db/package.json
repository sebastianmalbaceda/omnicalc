{
  "name": "@omnicalc/db",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@neondatabase/serverless": "^1.0.0"
  },
  "devDependencies": {
    "@omnicalc/tsconfig": "workspace:*",
    "prisma": "^6.5.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "rimraf": "^6.0.0"
  }
}
